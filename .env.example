NODE_ENV=development
PORT=5555
API_PREFIX=api/v1

THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Comma-separated origins (required in production)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

DATABASE_URL="postgresql://admin:admin@localhost:5432/nestjs2026-learning"
DB_USER="admin"
DB_PASSWORD="admin"
DB_NAME="nestjs2026-learning"
DB_HOST="localhost"
DB_PORT="5432"

# At least 16 characters in development; 32+ and unique in production
JWT_SECRET=dev-secret-key-min-16-chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d